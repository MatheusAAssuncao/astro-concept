---
import { MessageCircle } from "lucide-astro";
---

<a
  href="https://api.whatsapp.com/message/MJMV6SHR5VEJA1"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar via WhatsApp"
  class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-gold text-primary-foreground shadow-xl transition hover:scale-105 hover:shadow-2xl"
>
  <MessageCircle class="h-6 w-6" />
  <span class="absolute inset-0 -z-10 animate-ping rounded-full bg-gold/40"></span>
</a>
