---
import { ArrowUpRight } from "lucide-astro";
import { getServicos } from "../lib/directus";
import { getIconComponent, gerarSlug } from "../lib/helpers";

const servicos = await getServicos();

// Mapear serviços do Directus
const services = servicos.map((servico) => ({
  titulo: servico.titulo,
  descricao: servico.descricao,
  Icon: getIconComponent(servico.icone),
  hasDetail: !!(servico.imagem && servico.conteudo),
  slug: gerarSlug(servico.titulo)
}));
---

<section id="servicos" class="bg-background py-28">
  <div class="container-prose">
    <div class="mx-auto max-w-2xl text-center">
      <span class="gold-divider"><span class="h-px w-8 bg-current"></span> Os nossos serviços <span class="h-px w-8 bg-current"></span></span>
      <h2 class="mt-5 text-4xl sm:text-5xl">Estética avançada, atenção ao detalhe</h2>
      <p class="mt-5 text-muted-foreground">
        Uma carta de tratamentos pensada para cuidar da sua imagem com método e sofisticação.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-3">
      {services.map(({ titulo, descricao, Icon, hasDetail, slug }) => {
        const Component = hasDetail ? 'a' : 'article';
        const linkProps = hasDetail ? { href: `/servicos/${slug}` } : {};
        
        return (
          <Component 
            {...linkProps}
            class="group relative overflow-hidden rounded-2xl border border-border bg-card p-8 transition-all duration-500 hover:scale-[1.02] hover:border-gold/60 hover:shadow-[0_20px_60px_-30px_oklch(0.745_0.122_80/0.5)]"
          >
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gold/60 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
            
            {hasDetail && (
              <div class="absolute right-4 top-4 flex h-8 w-8 items-center justify-center rounded-full bg-gold/10 text-gold opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <ArrowUpRight class="h-4 w-4" stroke-width={2} />
              </div>
            )}
            
            <Icon class="h-8 w-8 text-gold" stroke-width={1.25} />
            <h3 class="mt-6 text-2xl">{titulo}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground md:max-h-0 md:overflow-hidden md:opacity-0 md:transition-all md:duration-500 md:group-hover:max-h-32 md:group-hover:opacity-100">
              {descricao}
            </p>
          </Component>
        );
      })}
    </div>

    <div class="mx-auto mt-20 max-w-3xl rounded-2xl border border-gold/30 bg-card/60 px-8 py-10 text-center">
      <span class="gold-divider">Marcações</span>
      <p class="mt-4 font-serif text-2xl text-foreground sm:text-3xl">
        O atendimento funciona exclusivamente por marcação.
      </p>
      <p class="mt-3 text-sm text-muted-foreground">
        Reserve o seu momento connosco para uma experiência dedicada e sem esperas.
      </p>
    </div>
  </div>
</section>
