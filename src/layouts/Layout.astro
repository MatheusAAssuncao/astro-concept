---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Depilação Laser & Micropigmentação em Algés | Concept Estética",
  description = "Centro de estética avançada em Algés. Especialistas em depilação a laser, micropigmentação, extensão de pestanas, tratamentos faciais e corporais. Marque a sua avaliação.",
  image = "/og-image.jpg",
} = Astro.props;

const siteUrl = "https://conceptestetica.pt";
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
const fullImageUrl = new URL(image, siteUrl).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "name": "Concept Estética",
  "description": "Centro de estética avançada especializada em depilação a laser, micropigmentação, extensão de pestanas e tratamentos faciais em Lisboa.",
  "image": fullImageUrl,
  "url": siteUrl,
  "telephone": "+351928205944",
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Avenida Humberto Melo Pereira, 9",
    "addressLocality": "Algés",
    "addressRegion": "Lisboa",
    "postalCode": "1495-020",
    "addressCountry": "PT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "38.697891",
    "longitude": "-9.231264"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "10:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "15:00"
    }
  ],
  "sameAs": [
    "https://instagram.com/conceptestetica.pt",
    "https://widget.treatwell.pt/estabelecimento/concept-estetica"
  ],
  "areaServed": [
    {
      "@type": "City",
      "name": "Algés"
    },
    {
      "@type": "City",
      "name": "Oeiras"
    },
    {
      "@type": "City",
      "name": "Lisboa"
    }
  ]
};
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:site_name" content="Concept Estética" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
